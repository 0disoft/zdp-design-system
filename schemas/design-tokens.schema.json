{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "design-tokens.schema.json",
  "title": "ZDP design token document",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "name",
    "version",
    "color",
    "space",
    "radius",
    "font",
    "type",
    "breakpoint",
    "layer",
    "viewport",
    "control",
    "i18n",
    "shadow",
    "motion"
  ],
  "properties": {
    "$schema": {
      "const": "../schemas/design-tokens.schema.json"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "color": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "$ref": "#/$defs/colorToken"
        }
      }
    },
    "space": {
      "$ref": "#/$defs/stringMap"
    },
    "radius": {
      "$ref": "#/$defs/stringMap"
    },
    "font": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "size",
        "weight",
        "lineHeight"
      ],
      "properties": {
        "family": {
          "$ref": "#/$defs/stringMap"
        },
        "size": {
          "$ref": "#/$defs/stringMap"
        },
        "weight": {
          "$ref": "#/$defs/stringMap"
        },
        "lineHeight": {
          "$ref": "#/$defs/stringMap"
        }
      }
    },
    "type": {
      "$ref": "#/$defs/stringMap"
    },
    "breakpoint": {
      "$ref": "#/$defs/stringMap"
    },
    "layer": {
      "$ref": "#/$defs/stringMap"
    },
    "viewport": {
      "$ref": "#/$defs/stringMap"
    },
    "control": {
      "$ref": "#/$defs/stringMap"
    },
    "i18n": {
      "$ref": "#/$defs/stringMap"
    },
    "shadow": {
      "$ref": "#/$defs/stringMap"
    },
    "motion": {
      "$ref": "#/$defs/stringMap"
    }
  },
  "$defs": {
    "colorToken": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hex",
        "oklch"
      ],
      "properties": {
        "hex": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "oklch": {
          "type": "string",
          "pattern": "^oklch\\([^)]+\\)$"
        }
      }
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
