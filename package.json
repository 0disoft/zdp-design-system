{
  "name": "zdp-design-system",
  "version": "0.48.0",
  "private": false,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "ZDP design tokens, CSS, icons, and Svelte UI package boundary.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0disoft/zdp-design-system.git"
  },
  "exports": {
    ".": {
      "svelte": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles/index.css",
    "./brand-fonts.css": "./dist/styles/brand-fonts.css",
    "./expressive-fonts.css": "./dist/styles/expressive-fonts.css",
    "./locale-fonts.css": "./dist/styles/locale-fonts.css",
    "./share": {
      "types": "./dist/share.d.ts",
      "import": "./dist/share.js",
      "default": "./dist/share.js"
    },
    "./tokens": "./dist/tokens/zdp.tokens.json"
  },
  "files": [
    "dist/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "sideEffects": [
    "./dist/styles/index.css",
    "./dist/styles/brand-fonts.css",
    "./dist/styles/expressive-fonts.css",
    "./dist/styles/locale-fonts.css",
    "./dist/styles/tokens.css",
    "./dist/styles/components.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build",
    "tokens:generate": "bun scripts/generate-tokens.ts",
    "tokens:check": "bun scripts/generate-tokens.ts --check && bun scripts/check-tokens.ts",
    "consumer:check": "bun scripts/check-consumer-contract.ts",
    "share-icons:generate": "bun scripts/generate-share.ts",
    "share-icons:check": "bun scripts/generate-share.ts --check && bun scripts/check-share-icons.ts",
    "preview:check": "bun scripts/check-preview.ts && bun run styles:parity:check",
    "styles:parity:check": "bun scripts/check-component-style-parity.ts",
    "a11y:check": "bun scripts/check-storybook-a11y.ts",
    "a11y:runtime:check": "node scripts/check-storybook-runtime-a11y.mjs",
    "ssr:hydration:check": "node scripts/check-ssr-hydration.mjs",
    "browser:check": "node scripts/check-browser-accessibility.mjs",
    "type:check": "svelte-check --tsconfig ./tsconfig.json",
    "package:build": "bun scripts/generate-tokens.ts && bun scripts/generate-share.ts && bun scripts/build-package.ts",
    "package:check": "bun scripts/check-package.ts",
    "publish:check": "bun scripts/check-publish-readiness.ts",
    "release:artifact:check": "bun scripts/build-release-artifact.ts --check",
    "release:check": "bun scripts/check-release-workflow.ts && bun run release:artifact:check",
    "fixtures:check": "bun scripts/check-consumer-fixtures.ts",
    "storybook": "bun run dev",
    "storybook:build": "bun run build",
    "storybook:check": "bun scripts/check-storybook.ts",
    "check": "bun run tokens:check && bun run consumer:check && bun run share-icons:check && bun run preview:check && bun run storybook:check && bun run a11y:check && bun run a11y:runtime:check && bun run ssr:hydration:check && bun run type:check && bun run package:build && bun run package:check && bun run publish:check && bun run release:check && bun run fixtures:check"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.5.3",
    "@storybook/svelte-vite": "10.5.3",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tsconfig/svelte": "5.0.8",
    "@types/node": "26.1.1",
    "axe-core": "4.12.1",
    "playwright-core": "1.61.1",
    "simple-icons": "^16.27.0",
    "storybook": "10.5.3",
    "svelte": "^5.56.7",
    "svelte-check": "4.7.3",
    "typescript": "6.0.2",
    "vite": "^8.1.5"
  },
  "peerDependencies": {
    "svelte": "^5.56.0"
  }
}
