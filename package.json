{
  "name": "zdp-design-system",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "description": "ZDP design tokens, CSS, icons, and Svelte UI package boundary.",
  "exports": {
    ".": {
      "svelte": "./src/lib/index.ts",
      "types": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    },
    "./styles.css": "./src/styles/index.css",
    "./tokens": "./tokens/zdp.tokens.json"
  },
  "files": [
    "src/",
    "tokens/",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "./src/styles/index.css",
    "./src/styles/tokens.css",
    "./src/styles/components.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build",
    "tokens:check": "bun scripts/check-tokens.ts",
    "preview:check": "bun scripts/check-preview.ts",
    "storybook": "bun run dev",
    "storybook:build": "bun run build",
    "storybook:check": "bun scripts/check-storybook.ts",
    "check": "bun scripts/check-tokens.ts && bun scripts/check-preview.ts && bun scripts/check-storybook.ts"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@storybook/svelte-vite": "^10.4.0",
    "storybook": "^10.4.0",
    "svelte": "^5.0.0",
    "vite": "^7.0.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
