{
  "$schema": "https://zdp.zerodi.dev/schemas/design-tokens.schema.json",
  "name": "zdp-core",
  "version": "0.1.0",
  "color": {
    "ink": {
      "strong": "#111827",
      "normal": "#1f2937",
      "muted": "#667085",
      "inverse": "#ffffff"
    },
    "surface": {
      "canvas": "#f7f8fb",
      "panel": "#ffffff",
      "raised": "#f2f4f7",
      "inverse": "#111827"
    },
    "line": {
      "subtle": "#d0d5dd",
      "strong": "#98a2b3",
      "focus": "#2563eb"
    },
    "accent": {
      "primary": "#2563eb",
      "primaryStrong": "#1d4ed8",
      "primarySoft": "#dbeafe",
      "success": "#0f766e",
      "warning": "#b54708",
      "danger": "#b42318"
    }
  },
  "space": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem"
  },
  "radius": {
    "none": "0",
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "pill": "999px"
  },
  "font": {
    "family": {
      "sans": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "mono": "\"JetBrains Mono\", \"SFMono-Regular\", Consolas, monospace"
    },
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "md": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem"
    },
    "weight": {
      "regular": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.2",
      "normal": "1.5",
      "relaxed": "1.65"
    }
  },
  "shadow": {
    "focus": "0 0 0 3px rgba(37, 99, 235, 0.28)",
    "sm": "0 1px 2px rgba(16, 24, 40, 0.08)",
    "md": "0 8px 24px rgba(16, 24, 40, 0.12)"
  },
  "motion": {
    "fast": "120ms",
    "normal": "180ms"
  }
}
