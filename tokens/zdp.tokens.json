{
  "$schema": "https://zdp.zerodi.dev/schemas/design-tokens.schema.json",
  "name": "zdp-core",
  "version": "0.3.0",
  "color": {
    "ink": {
      "strong": {
        "hex": "#2f2418",
        "oklch": "oklch(27% 0.04 70)"
      },
      "normal": {
        "hex": "#4a3826",
        "oklch": "oklch(36% 0.05 70)"
      },
      "muted": {
        "hex": "#776955",
        "oklch": "oklch(50% 0.035 82)"
      },
      "inverse": {
        "hex": "#fff8ea",
        "oklch": "oklch(98% 0.025 86)"
      }
    },
    "surface": {
      "canvas": {
        "hex": "#f7f1e3",
        "oklch": "oklch(95% 0.03 86)"
      },
      "panel": {
        "hex": "#fff8ea",
        "oklch": "oklch(98% 0.025 86)"
      },
      "raised": {
        "hex": "#f1e4cc",
        "oklch": "oklch(91% 0.045 82)"
      },
      "inverse": {
        "hex": "#2f2418",
        "oklch": "oklch(27% 0.04 70)"
      }
    },
    "line": {
      "subtle": {
        "hex": "#d8c8ac",
        "oklch": "oklch(82% 0.045 82)"
      },
      "strong": {
        "hex": "#b89a6a",
        "oklch": "oklch(70% 0.08 76)"
      },
      "focus": {
        "hex": "#6d8fb7",
        "oklch": "oklch(63% 0.08 250)"
      }
    },
    "accent": {
      "primary": {
        "hex": "#6d8fb7",
        "oklch": "oklch(63% 0.08 250)"
      },
      "primaryStrong": {
        "hex": "#3f6286",
        "oklch": "oklch(47% 0.08 250)"
      },
      "primarySoft": {
        "hex": "#dce8f4",
        "oklch": "oklch(92% 0.035 250)"
      },
      "success": {
        "hex": "#8ba489",
        "oklch": "oklch(68% 0.055 140)"
      },
      "warning": {
        "hex": "#e7c97a",
        "oklch": "oklch(84% 0.1 86)"
      },
      "danger": {
        "hex": "#8e2e3d",
        "oklch": "oklch(43% 0.12 25)"
      }
    }
  },
  "space": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem"
  },
  "radius": {
    "none": "0",
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.5rem",
    "pill": "999px"
  },
  "font": {
    "family": {
      "sans": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "serif": "Cardo, Georgia, \"Times New Roman\", ui-serif, serif",
      "display": "Cinzel, Cardo, Georgia, \"Times New Roman\", ui-serif, serif",
      "mono": "\"JetBrains Mono\", \"SFMono-Regular\", Consolas, monospace"
    },
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "md": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem"
    },
    "weight": {
      "regular": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.2",
      "normal": "1.5",
      "relaxed": "1.65"
    }
  },
  "shadow": {
    "focus": "0 0 0 3px rgba(109, 143, 183, 0.34)",
    "sm": "0 1px 2px rgba(82, 59, 32, 0.1)",
    "md": "0 10px 28px rgba(82, 59, 32, 0.14)"
  },
  "motion": {
    "fast": "120ms",
    "normal": "180ms"
  }
}
