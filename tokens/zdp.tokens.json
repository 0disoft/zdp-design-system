{
  "$schema": "https://zdp.zerodi.dev/schemas/design-tokens.schema.json",
  "name": "zdp-core",
  "version": "0.2.0",
  "color": {
    "ink": {
      "strong": {
        "hex": "#111827",
        "oklch": "oklch(21% 0.035 265)"
      },
      "normal": {
        "hex": "#1f2937",
        "oklch": "oklch(28% 0.035 260)"
      },
      "muted": {
        "hex": "#667085",
        "oklch": "oklch(55% 0.035 260)"
      },
      "inverse": {
        "hex": "#ffffff",
        "oklch": "oklch(100% 0 0)"
      }
    },
    "surface": {
      "canvas": {
        "hex": "#f7f8fb",
        "oklch": "oklch(98% 0.006 260)"
      },
      "panel": {
        "hex": "#ffffff",
        "oklch": "oklch(100% 0 0)"
      },
      "raised": {
        "hex": "#f2f4f7",
        "oklch": "oklch(96% 0.008 260)"
      },
      "inverse": {
        "hex": "#111827",
        "oklch": "oklch(21% 0.035 265)"
      }
    },
    "line": {
      "subtle": {
        "hex": "#d0d5dd",
        "oklch": "oklch(86% 0.018 260)"
      },
      "strong": {
        "hex": "#98a2b3",
        "oklch": "oklch(70% 0.03 260)"
      },
      "focus": {
        "hex": "#2563eb",
        "oklch": "oklch(54% 0.19 260)"
      }
    },
    "accent": {
      "primary": {
        "hex": "#2563eb",
        "oklch": "oklch(54% 0.19 260)"
      },
      "primaryStrong": {
        "hex": "#1d4ed8",
        "oklch": "oklch(48% 0.2 260)"
      },
      "primarySoft": {
        "hex": "#dbeafe",
        "oklch": "oklch(92% 0.045 255)"
      },
      "success": {
        "hex": "#0f766e",
        "oklch": "oklch(48% 0.1 190)"
      },
      "warning": {
        "hex": "#b54708",
        "oklch": "oklch(56% 0.14 55)"
      },
      "danger": {
        "hex": "#b42318",
        "oklch": "oklch(50% 0.17 30)"
      }
    }
  },
  "space": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem"
  },
  "radius": {
    "none": "0",
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "pill": "999px"
  },
  "font": {
    "family": {
      "sans": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "mono": "\"JetBrains Mono\", \"SFMono-Regular\", Consolas, monospace"
    },
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "md": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem"
    },
    "weight": {
      "regular": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.2",
      "normal": "1.5",
      "relaxed": "1.65"
    }
  },
  "shadow": {
    "focus": "0 0 0 3px rgba(37, 99, 235, 0.28)",
    "sm": "0 1px 2px rgba(16, 24, 40, 0.08)",
    "md": "0 8px 24px rgba(16, 24, 40, 0.12)"
  },
  "motion": {
    "fast": "120ms",
    "normal": "180ms"
  }
}
